#!/usr/bin/env python3
from __future__ import annotations

import argparse
import fcntl
import json
import os
import signal
import socket
import sys
import time
from contextlib import contextmanager
from datetime import datetime, timezone
from pathlib import Path
from typing import Any, Iterator


VERSION = "0.7.3"
MANAGED_MARKER = "FOLLOW_UP_MANAGED=1"
STATE_DIR_NAME = ".follow-up"
EVENT_FILE_NAME = "event.json"
LOCK_FILE_NAME = "event.lock"
DEFAULT_HOOK_TIMEOUT_SECONDS = 7200
HOOK_TIMEOUT_MARGIN_SECONDS = 30
DEFAULT_COMMAND_TIMEOUT_SECONDS = 3600
DEFAULT_HOOK_POLL_SECONDS = 10
DEFAULT_ARM_MAX_AGE_SECONDS = 120
DEFAULT_FAILURE_PROMPT = (
    "The previous command failed. Inspect the Codex command output, identify the likely cause, "
    "and decide whether to fix and rerun the failing command or report the blocker with evidence."
)


class UserError(Exception):
    pass


class HookInterrupted(BaseException):
    def __init__(self, signum: int) -> None:
        self.signum = signum
        super().__init__(f"hook interrupted by signal {signum}")


def now_iso() -> str:
    return datetime.now(timezone.utc).isoformat(timespec="seconds").replace("+00:00", "Z")


def now_unix() -> float:
    return time.time()


def codex_home() -> Path:
    return Path(os.environ.get("CODEX_HOME", "~/.codex")).expanduser()


def env_override(name: str) -> str | None:
    return os.environ.get(name)


def hooks_file() -> Path:
    override = env_override("FOLLOW_UP_HOOKS_FILE")
    if override:
        return Path(override).expanduser()
    return codex_home() / "hooks.json"


def workspace_root(cwd: Path) -> Path:
    current = cwd.expanduser().absolute()
    for path in (current, *current.parents):
        git_path = path / ".git"
        if git_path.is_file() or (git_path / "config").is_file():
            return path
    return current


def state_root(cwd: Path | None = None) -> Path:
    override = env_override("FOLLOW_UP_STATE_DIR")
    if override:
        return Path(override).expanduser()
    return workspace_root(cwd or Path.cwd()) / STATE_DIR_NAME


def event_file(cwd: Path | None = None) -> Path:
    return state_root(cwd) / EVENT_FILE_NAME


def lock_file(cwd: Path | None = None) -> Path:
    return state_root(cwd) / LOCK_FILE_NAME


def read_json(path: Path, default: Any = None) -> Any:
    try:
        with path.open("r", encoding="utf-8") as fh:
            return json.load(fh)
    except FileNotFoundError:
        return default


def atomic_write_json(path: Path, data: Any) -> None:
    path.parent.mkdir(parents=True, exist_ok=True)
    tmp = path.with_name(f".{path.name}.tmp.{os.getpid()}.{time.time_ns()}")
    with tmp.open("w", encoding="utf-8") as fh:
        json.dump(data, fh, indent=2, sort_keys=True)
        fh.write("\n")
    os.replace(tmp, path)


@contextmanager
def locked_event(cwd: Path | None = None) -> Iterator[None]:
    path = lock_file(cwd)
    path.parent.mkdir(parents=True, exist_ok=True)
    with path.open("a+", encoding="utf-8") as fh:
        fcntl.flock(fh.fileno(), fcntl.LOCK_EX)
        try:
            yield
        finally:
            fcntl.flock(fh.fileno(), fcntl.LOCK_UN)


def load_event(cwd: Path | None = None) -> dict[str, Any] | None:
    data = read_json(event_file(cwd))
    return data if isinstance(data, dict) else None


def write_event(event: dict[str, Any], cwd: Path | None = None) -> None:
    atomic_write_json(event_file(cwd), event)


def clear_event(cwd: Path | None = None) -> None:
    try:
        event_file(cwd).unlink()
    except FileNotFoundError:
        pass


def json_hook_response(reason: str) -> None:
    print(json.dumps({"decision": "block", "reason": reason}, ensure_ascii=False))


def parse_int(value: str, name: str) -> int:
    try:
        return int(value)
    except ValueError as exc:
        raise argparse.ArgumentTypeError(f"{name} must be an integer") from exc


def parse_positive_int(value: str, name: str) -> int:
    parsed = parse_int(value, name)
    if parsed <= 0:
        raise argparse.ArgumentTypeError(f"{name} must be positive")
    return parsed


def env_positive_int(name: str, default: int) -> int:
    value = env_override(name)
    if value is None or value == "":
        return default
    try:
        return parse_positive_int(value, name)
    except argparse.ArgumentTypeError as exc:
        raise UserError(str(exc)) from exc


def hook_timeout_seconds() -> int:
    return env_positive_int("FOLLOW_UP_HOOK_TIMEOUT", DEFAULT_HOOK_TIMEOUT_SECONDS)


def max_command_timeout_seconds() -> int:
    max_seconds = effective_hook_timeout_seconds() - HOOK_TIMEOUT_MARGIN_SECONDS
    if max_seconds <= 0:
        raise UserError("installed follow-up hook timeout is too small for follow-up timeout guard")
    return max_seconds


def validate_command_timeout(seconds: int) -> int:
    max_seconds = max_command_timeout_seconds()
    if seconds > max_seconds:
        raise UserError(
            f"follow-up --timeout must be <= {max_seconds} seconds so the hook can report before "
            f"its {effective_hook_timeout_seconds()} second process timeout"
        )
    return seconds


def default_command_timeout_seconds() -> int:
    configured = env_positive_int("FOLLOW_UP_COMMAND_TIMEOUT_SECONDS", DEFAULT_COMMAND_TIMEOUT_SECONDS)
    return validate_command_timeout(configured)


def current_session_id() -> str | None:
    for name in ("CODEX_THREAD_ID", "CODEX_SESSION_ID"):
        value = os.environ.get(name)
        if value:
            return value
    return None


def require_session_id() -> str:
    session_id = current_session_id()
    if not session_id:
        raise UserError(
            "Codex session id not found; follow-up requires CODEX_THREAD_ID or CODEX_SESSION_ID "
            "to avoid cross-session delivery"
        )
    return session_id


def hook_session_id(hook_input: dict[str, Any]) -> str | None:
    value = hook_input.get("session_id")
    return value if isinstance(value, str) and value else None


def persistent_hook_present() -> bool:
    return installed_hook_timeout_seconds() is not None


def managed_hook_timeouts() -> list[int]:
    try:
        data = read_json(hooks_file(), {})
    except Exception:
        return []
    if not isinstance(data, dict):
        return []
    hooks = data.get("hooks")
    if not isinstance(hooks, dict):
        return []
    stop_groups = hooks.get("Stop", [])
    if not isinstance(stop_groups, list):
        return []
    timeouts: list[int] = []
    for group in stop_groups:
        if not isinstance(group, dict):
            continue
        group_hooks = group.get("hooks", [])
        if not isinstance(group_hooks, list):
            continue
        for hook in group_hooks:
            if not isinstance(hook, dict):
                continue
            command = hook.get("command")
            if isinstance(command, str) and MANAGED_MARKER in command and "--hook" in command:
                timeout = hook.get("timeout")
                if isinstance(timeout, int) and timeout > 0:
                    timeouts.append(timeout)
    return timeouts


def installed_hook_timeout_seconds() -> int | None:
    timeouts = managed_hook_timeouts()
    if not timeouts:
        return None
    return min(timeouts)


def effective_hook_timeout_seconds() -> int:
    return installed_hook_timeout_seconds() or hook_timeout_seconds()


def event_id(prefix: str = "") -> str:
    timestamp = datetime.now(timezone.utc).strftime("%Y%m%dT%H%M%SZ")
    return f"{prefix}{timestamp}-{os.getpid()}-{time.time_ns() % 100000000:08d}"


def process_start_time(pid: int) -> str | None:
    stat_path = Path(f"/proc/{pid}/stat")
    try:
        content = stat_path.read_text(encoding="utf-8")
    except OSError:
        return None
    marker = ") "
    marker_index = content.rfind(marker)
    if marker_index < 0:
        return None
    fields = content[marker_index + len(marker) :].split()
    if len(fields) <= 19:
        return None
    return fields[19]


def process_is_running(pid: int, start_time: str | None = None) -> bool:
    if pid <= 0:
        return False
    try:
        os.kill(pid, 0)
    except ProcessLookupError:
        return False
    except PermissionError:
        return True
    if start_time:
        current_start_time = process_start_time(pid)
        if current_start_time is not None and current_start_time != start_time:
            return False
    return True


def claimed_hook_is_running(event: dict[str, Any]) -> bool:
    if event.get("claimed_host") not in (None, socket.gethostname()):
        return True
    pid = event.get("claimed_pid")
    if not isinstance(pid, int):
        return True
    start_time = event.get("claimed_pid_start_time")
    return process_is_running(pid, start_time if isinstance(start_time, str) else None)


def exit_code_from_env() -> int | None:
    value = env_override("FOLLOW_UP_EXIT_CODE")
    if value is None or value == "":
        return None
    try:
        return parse_int(value, "FOLLOW_UP_EXIT_CODE")
    except argparse.ArgumentTypeError as exc:
        raise UserError(str(exc)) from exc


def result_status(exit_code: int | None) -> str:
    if exit_code is None:
        return "completed"
    if exit_code == 0:
        return "succeeded"
    return "failed"


def join_feedback(items: list[str]) -> str:
    if "--" in items:
        raise UserError(
            'follow-up does not execute commands; use: follow-up "feedback"; '
            'command; rc=$?; follow-up --finished --exit-code "$rc"'
        )
    feedback = " ".join(items).strip()
    if not feedback:
        raise UserError('usage: follow-up "feedback text"')
    return feedback


def arm_event(feedback: str, timeout_seconds: int) -> None:
    created_at = now_iso()
    created_at_unix = now_unix()
    cwd = Path.cwd()
    workspace = workspace_root(cwd)
    session_id = require_session_id()
    max_age = env_positive_int("FOLLOW_UP_ARM_MAX_AGE_SECONDS", DEFAULT_ARM_MAX_AGE_SECONDS)

    event = {
        "schema_version": 3,
        "version": VERSION,
        "mode": "codex-command-follow-up",
        "event_id": event_id(),
        "status": "pending",
        "created_at": created_at,
        "created_at_unix": created_at_unix,
        "expires_at_unix": created_at_unix + max_age,
        "cwd": str(cwd),
        "workspace_root": str(workspace),
        "host": socket.gethostname(),
        "feedback": feedback,
        "session_id": session_id,
        "timeout_seconds": validate_command_timeout(timeout_seconds),
        "hook_timeout_seconds": effective_hook_timeout_seconds(),
    }

    with locked_event():
        write_event(event)

    if not persistent_hook_present():
        print(
            "warning: persistent Stop hook not found; run scripts/install-codex and restart Codex before relying on follow-up.",
            file=sys.stderr,
        )

    print(f"follow-up armed: {event['event_id']}")
    print(
        "follow-up agent instruction: after launching the combined shell command, stop the turn immediately. "
        "Do not poll the running session; the installed Stop hook waits for --finished.",
        file=sys.stderr,
    )


def finish_event(exit_code: int | None) -> None:
    session_id = require_session_id()
    cwd = Path.cwd()
    with locked_event(cwd):
        event = load_event(cwd)
        if not event:
            raise UserError("no active follow-up event in this workspace")
        if event.get("session_id") != session_id:
            raise UserError("active follow-up event belongs to a different Codex session")
        if request_workspace(event) != workspace_root(cwd):
            raise UserError("active follow-up event belongs to a different workspace")

        finished_at = now_iso()
        finished_at_unix = now_unix()
        event["status"] = "finished"
        event["result"] = {
            "status": result_status(exit_code),
            "exit_code": exit_code,
            "finished_at": finished_at,
            "finished_at_unix": finished_at_unix,
        }
        write_event(event, cwd)

    print(f"follow-up finished: {event.get('event_id', 'unknown')}")
    if exit_code is None:
        print("exit code: unknown")
    else:
        print(f"exit code: {exit_code}")


def load_hook_input() -> dict[str, Any]:
    raw = sys.stdin.read()
    if not raw.strip():
        return {}
    try:
        data = json.loads(raw)
    except json.JSONDecodeError:
        return {}
    return data if isinstance(data, dict) else {}


def request_workspace(event: dict[str, Any]) -> Path | None:
    value = event.get("workspace_root")
    if isinstance(value, str) and value:
        return Path(value).expanduser().absolute()
    cwd = event.get("cwd")
    if isinstance(cwd, str) and cwd:
        return workspace_root(Path(cwd))
    return None


def hook_workspace(hook_cwd: Path) -> Path:
    return workspace_root(hook_cwd)


def event_matches_context(event: dict[str, Any], hook_input: dict[str, Any], hook_cwd: Path) -> bool:
    session_id = hook_session_id(hook_input)
    if not isinstance(session_id, str) or event.get("session_id") != session_id:
        return False

    workspace = request_workspace(event)
    if workspace is None:
        return False
    return workspace == hook_workspace(hook_cwd)


def is_event_fresh(event: dict[str, Any], current_time: float) -> bool:
    expires_at = event.get("expires_at_unix")
    if isinstance(expires_at, (int, float)):
        return current_time <= float(expires_at)

    created_at = event.get("created_at_unix")
    if not isinstance(created_at, (int, float)):
        return False
    max_age = env_positive_int("FOLLOW_UP_ARM_MAX_AGE_SECONDS", DEFAULT_ARM_MAX_AGE_SECONDS)
    return current_time - float(created_at) <= max_age


def event_timeout_seconds(event: dict[str, Any]) -> int:
    value = event.get("timeout_seconds")
    if isinstance(value, int) and value > 0:
        return min(value, max_command_timeout_seconds())
    return default_command_timeout_seconds()


def claim_is_active(event: dict[str, Any], current_time: float) -> bool:
    expires_at = event.get("claim_expires_at_unix")
    return isinstance(expires_at, (int, float)) and current_time <= float(expires_at)


def claim_event(hook_input: dict[str, Any], hook_cwd: Path, hook_id: str) -> bool:
    if not event_file(hook_cwd).exists():
        return False
    with locked_event(hook_cwd):
        if not event_file(hook_cwd).exists():
            return False
        event = load_event(hook_cwd)
        if not event:
            return False
        if not event_matches_context(event, hook_input, hook_cwd):
            return False
        current_time = now_unix()
        status = event.get("status")
        if status in ("pending", "finished") and not event.get("timeout_count") and not is_event_fresh(event, current_time):
            clear_event(hook_cwd)
            return False

        if status not in ("pending", "claimed", "timeout_waiting", "finished"):
            return False
        if event.get("claimed_by") and event.get("claimed_by") != hook_id:
            if not claimed_hook_is_running(event):
                clear_event(hook_cwd)
                return False
            if claim_is_active(event, current_time):
                return False

        poll_seconds = env_positive_int("FOLLOW_UP_HOOK_POLL_SECONDS", DEFAULT_HOOK_POLL_SECONDS)
        claim_grace = max(HOOK_TIMEOUT_MARGIN_SECONDS, poll_seconds * 2)
        timeout_seconds = event_timeout_seconds(event)
        event["claimed_by"] = hook_id
        event["claimed_pid"] = os.getpid()
        event["claimed_pid_start_time"] = process_start_time(os.getpid())
        event["claimed_host"] = socket.gethostname()
        event["claimed_at"] = now_iso()
        event["claimed_at_unix"] = current_time
        event["claim_expires_at_unix"] = current_time + timeout_seconds + claim_grace
        event["hook_session_id"] = hook_session_id(hook_input)
        event["hook_cwd"] = hook_input.get("cwd")
        if status in ("pending", "claimed", "timeout_waiting"):
            event["status"] = "claimed"
        write_event(event, hook_cwd)
        return True


def read_claimed_event(hook_cwd: Path, hook_id: str) -> dict[str, Any] | None:
    with locked_event(hook_cwd):
        event = load_event(hook_cwd)
        if not event or event.get("claimed_by") != hook_id:
            return None
        return event


def clear_claimed_event(hook_cwd: Path, hook_id: str) -> dict[str, Any] | None:
    with locked_event(hook_cwd):
        event = load_event(hook_cwd)
        if not event or event.get("claimed_by") != hook_id:
            return None
        clear_event(hook_cwd)
        return event


def mark_timed_out_event(hook_cwd: Path, hook_id: str, timeout_seconds: int) -> dict[str, Any] | None:
    with locked_event(hook_cwd):
        event = load_event(hook_cwd)
        if event and event.get("claimed_by") == hook_id and event.get("status") != "finished":
            event["status"] = "timeout_waiting"
            event["last_timeout_at"] = now_iso()
            event["last_timeout_at_unix"] = now_unix()
            event["last_timeout_seconds"] = timeout_seconds
            timeout_count = event.get("timeout_count")
            event["timeout_count"] = (timeout_count if isinstance(timeout_count, int) else 0) + 1
            event["last_timed_out_by"] = hook_id
            event.pop("claimed_by", None)
            event.pop("claimed_pid", None)
            event.pop("claimed_pid_start_time", None)
            event.pop("claimed_host", None)
            event.pop("claim_expires_at_unix", None)
            write_event(event, hook_cwd)
            return event
        return None


def clear_interrupted_event(hook_cwd: Path, hook_id: str) -> bool:
    with locked_event(hook_cwd):
        event = load_event(hook_cwd)
        if not event or event.get("claimed_by") != hook_id:
            return False
        clear_event(hook_cwd)
        return True


def install_interrupt_handlers() -> None:
    def handle_signal(signum: int, _frame: Any) -> None:
        raise HookInterrupted(signum)

    for name in ("SIGTERM", "SIGINT", "SIGHUP", "SIGQUIT"):
        signum = getattr(signal, name, None)
        if signum is not None:
            signal.signal(signum, handle_signal)


def build_event_feedback(event: dict[str, Any]) -> str:
    result = event.get("result")
    if not isinstance(result, dict):
        result = {}

    exit_code = result.get("exit_code")
    failed = isinstance(exit_code, int) and exit_code != 0

    lines = [
        "# Follow Up",
        "",
        "The previous Codex shell command has completed. Use the command output already visible in the transcript.",
        "",
        "## Follow-up Instruction",
        "",
        str(event.get("feedback", "")).strip() or "(none)",
        "",
        "## Result",
        "",
        f"- Exit code: `{exit_code if exit_code is not None else 'unknown'}`",
        f"- Status: `{result.get('status', 'unknown')}`",
    ]

    if failed:
        lines.extend(["", "## Default Failure Handling", "", DEFAULT_FAILURE_PROMPT])
    elif exit_code is None:
        lines.extend(
            [
                "",
                "## Exit Code Note",
                "",
                "No exit code was recorded. If the preceding output shows a failure, inspect it and recover before continuing.",
            ]
        )

    return "\n".join(lines)


def build_timeout_feedback(event: dict[str, Any], timeout_seconds: int) -> str:
    elapsed = int(now_unix() - float(event.get("created_at_unix", now_unix())))
    lines = [
        "# Follow Up Timeout",
        "",
        "The long-running shell command has not recorded completion before the follow-up timeout gate.",
        "",
        "## What To Do Now",
        "",
        "Inspect the running command only enough to decide whether it is making normal progress or appears stuck.",
        "If it is stuck, diagnose the cause and either fix/retry or report the blocker with evidence.",
        "If it appears to be running normally and just needs more time, end this turn immediately again. Do not create a new follow-up event and do not rerun the command; the next Stop hook will wait for another timeout interval.",
        "",
        "## Event",
        "",
        f"- Event id: `{event.get('event_id', 'unknown')}`",
        f"- Timeout gate: `{timeout_seconds}` seconds",
        f"- Elapsed since armed: `{elapsed}` seconds",
        f"- Timeout count: `{event.get('timeout_count', 0)}`",
        f"- Working directory: `{event.get('cwd', 'unknown')}`",
        f"- Session id: `{event.get('session_id', 'unknown')}`",
        "",
        "The original shell suffix is still responsible for running `follow-up --finished --exit-code \"$rc\"` when the command exits.",
    ]
    return "\n".join(lines)


def run_hook() -> int:
    hook_input = load_hook_input()
    hook_cwd_value = hook_input.get("cwd")
    hook_cwd = Path(hook_cwd_value) if isinstance(hook_cwd_value, str) else Path.cwd()
    if not hook_session_id(hook_input):
        return 0

    hook_id = event_id("hook-")
    if not claim_event(hook_input, hook_cwd, hook_id):
        return 0
    install_interrupt_handlers()

    try:
        event = read_claimed_event(hook_cwd, hook_id)
        if not event:
            return 0
        wait_seconds = event_timeout_seconds(event)
        poll_seconds = env_positive_int("FOLLOW_UP_HOOK_POLL_SECONDS", DEFAULT_HOOK_POLL_SECONDS)
        deadline = now_unix() + wait_seconds

        while True:
            event = read_claimed_event(hook_cwd, hook_id)
            if not event:
                return 0
            if event.get("status") == "finished" and isinstance(event.get("result"), dict):
                event = clear_claimed_event(hook_cwd, hook_id)
                if event:
                    json_hook_response(build_event_feedback(event))
                return 0

            remaining = deadline - now_unix()
            if remaining <= 0:
                event = mark_timed_out_event(hook_cwd, hook_id, wait_seconds)
                if event:
                    json_hook_response(build_timeout_feedback(event, wait_seconds))
                return 0
            time.sleep(min(poll_seconds, remaining))
    except HookInterrupted as exc:
        clear_interrupted_event(hook_cwd, hook_id)
        return 128 + exc.signum


def print_status() -> None:
    print(f"state dir: {state_root()}")
    print(f"event file: {event_file()}")
    print(f"hooks file: {hooks_file()}")
    with locked_event():
        event = load_event()
    if not event:
        print("event: none")
        return

    result = event.get("result")
    if not isinstance(result, dict):
        result = {}
    print(f"event: {event.get('event_id', 'unknown')}")
    print(f"  status: {event.get('status', 'unknown')}")
    print(f"  timeout: {event.get('timeout_seconds', 'unknown')}")
    print(f"  timeout_count: {event.get('timeout_count', 0)}")
    print(f"  exit: {result.get('exit_code', 'unknown')}")
    print(f"  session: {event.get('session_id', 'unknown')}")
    print(f"  claimed_by: {event.get('claimed_by', 'none')}")
    print(f"  feedback: {event.get('feedback', '')}")


def build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(
        prog="follow-up",
        description="Arm or finish follow-up feedback for the installed Codex Stop hook.",
    )
    parser.add_argument("--version", action="store_true", help="print version and exit")
    parser.add_argument("--status", action="store_true", help="show the active follow-up event")
    parser.add_argument("--finished", action="store_true", help="mark the active follow-up event finished")
    parser.add_argument(
        "--timeout",
        type=lambda value: parse_positive_int(value, "--timeout"),
        default=None,
        help="expected maximum command runtime in seconds before the hook asks Codex to inspect progress",
    )
    parser.add_argument(
        "--exit-code",
        type=lambda value: parse_int(value, "--exit-code"),
        default=None,
        help="exit code from the preceding command; use --exit-code \"$rc\" after saving $?",
    )
    parser.add_argument("feedback", nargs=argparse.REMAINDER)
    return parser


def main(argv: list[str]) -> int:
    if argv and argv[0] == "--hook":
        return run_hook()

    try:
        ns = build_parser().parse_args(argv)
        if ns.version:
            print(VERSION)
            return 0
        if ns.status:
            print_status()
            return 0
        if ns.finished:
            if ns.feedback:
                raise UserError("--finished does not accept feedback text")
            if ns.timeout is not None:
                raise UserError("--timeout is only valid when arming a follow-up event")
            exit_code = ns.exit_code
            if exit_code is None:
                exit_code = exit_code_from_env()
            finish_event(exit_code)
            return 0
        if ns.exit_code is not None:
            raise UserError("--exit-code is only valid with --finished")
        timeout_seconds = validate_command_timeout(ns.timeout) if ns.timeout is not None else default_command_timeout_seconds()
        arm_event(join_feedback(list(ns.feedback)), timeout_seconds)
        return 0
    except UserError as exc:
        print(f"follow-up: {exc}", file=sys.stderr)
        return 2


if __name__ == "__main__":
    raise SystemExit(main(sys.argv[1:]))
